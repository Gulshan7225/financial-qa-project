# Copy this file to .env and fill in values as needed.
# The application runs perfectly well with NONE of these set (open, LLM-less demo mode).

# --- Security ---
# If set, all API endpoints require header "X-API-Key: <value>".
# Leave blank to disable auth for local development/demo.
FINQA_API_KEY=

# Max upload size in MB (default 25)
FINQA_MAX_UPLOAD_MB=25

# --- Optional LLM enrichment ---
# If set, enables: (1) vision-based chart-to-data description, and
# (2) fluent LLM-synthesized answers for open-ended questions (still
# strictly grounded in retrieved report content -- numeric facts are
# NEVER sourced from the LLM, only from deterministic table parsing).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Number of retrieved chunks used for the retrieval-fallback QA path
FINQA_TOP_K=5
